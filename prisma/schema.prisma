datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  password          String
  resumes           Resume[]
  codingSubmissions CodingSubmission[]
  quizAttempts      QuizAttempt[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Resume {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String   @default("Untitled Resume")
  content      Json     @default("{}")
  personalInfo Json     @default("{}")
  experience   Json     @default("[]")
  education    Json     @default("[]")
  skills       Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CodingQuestion {
  id          String             @id @default(uuid())
  title       String
  description String             @db.Text
  testCases   Json               @default("[]")
  difficulty  String             @default("Medium")
  submissions CodingSubmission[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model AptitudeQuiz {
  id            String        @id @default(uuid())
  question      String        @db.Text
  options       Json          @default("[]")
  correctAnswer String
  category      String?
  attempts      QuizAttempt[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CodingSubmission {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  codingQuestionId String
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
  code             String         @db.Text
  status           String
  score            Int?
  language         String         @default("javascript")
  createdAt        DateTime       @default(now())
}

model QuizAttempt {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  aptitudeQuizId String
  aptitudeQuiz   AptitudeQuiz @relation(fields: [aptitudeQuizId], references: [id], onDelete: Cascade)
  userAnswer     String
  isCorrect      Boolean
  createdAt      DateTime     @default(now())
}
